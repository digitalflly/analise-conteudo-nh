# Copie este arquivo para ".env" (local) ou configure no painel do Vercel.

# Sua chave de API da Windsor.ai (Settings → API key em onboard.windsor.ai)
WINDSOR_API_KEY=cole_sua_chave_aqui

# (Opcional) Restringe a um único Instagram conectado, caso a chave tenha vários.
# ID da conta da Nathalia:
WINDSOR_IG_ACCOUNT_ID=17841401155274275

# (Opcional) Janela de histórico em dias (padrão 180)
# WINDSOR_DAYS=180

# (Opcional) Data inicial fixa YYYY-MM-DD (sobrepõe WINDSOR_DAYS)
# WINDSOR_DATE_FROM=2026-01-01
