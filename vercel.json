{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/refresh.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/refresh",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
